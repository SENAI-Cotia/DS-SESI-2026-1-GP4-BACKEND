// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id          Int      @id @default(autoincrement())
  email       String   @unique // nao pode repetir o email
  nome        String
  telefone    String
  cpf         String   @unique
  password    String
  tipoUsuario String
  pedidos     Pedido[] // um usuario pode ter varios pedidos
}

model Pedido {
  id        Int          @id @default(autoincrement())
  status    String
  total     Float
  senha     Int
  usuarioId Int // guarda o id do usuario
  itens     ItemPedido[] // um pedido pode ter varios itens
  usuario   Usuario      @relation(fields: [usuarioId], references: [id]) // liga as tabelas
  pagamento Pagamento?
  createdAt DateTime @default(now())
}

model ItemPedido {
  id         Int      @id @default(autoincrement())
  quantidade Int
  pedidoId   Int
  pedido     Pedido   @relation(fields: [pedidoId], references: [id]) // liga as tabelas
  alimentoId Int
  alimento   Alimento @relation(fields: [alimentoId], references: [id]) // liga as tabelas
}

model Alimento {
  id           Int          @id @default(autoincrement())
  nome         String
  preco        Float
  validade     String
  ingredientes String
  unidades     Int
  itens        ItemPedido[]
}

model Pagamento {
  id       Int    @id @default(autoincrement())
  valor    Float
  pedidoId Int @unique
  pedidos  Pedido @relation(fields: [pedidoId], references: [id])
}
